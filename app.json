{
  "expo": {
    "name": "Run Yatra",
    "slug": "runyatra",
    "version": "1.0.0",

    "orientation": "portrait",

    "userInterfaceStyle": "dark",

    "icon": "./assets/icon.png",

    "scheme": "runyatra",

    "plugins": [
      "expo-router"
    ],

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nextgen.terrarun",
      "googleServicesFile": "./GoogleService-Info.plist",
      "config": {
        "googleMapsApiKey": "AIzaSyBb6ibrRnQPkn2iwEhsNcfwsjuU_odex4s"
      }
    },

    "android": {
      "package": "com.nextgen.TERRARUN",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBb6ibrRnQPkn2iwEhsNcfwsjuU_odex4s"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "backgroundColor": "#1A0D0A"
      }
    },

    "web": {
      "favicon": "./assets/favicon.png"
    },

    "experiments": {
      "typedRoutes": true
    }
  }
}